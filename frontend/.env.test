# Mock environment values used exclusively by Playwright E2E tests.
# Real values are fetched from AWS SSM via make_env.py for dev/prod builds.
# NOTE: None of these point at real infrastructure. Network calls in E2E are
# intercepted at the Playwright level via page.route() — the URLs just have to
# be valid-looking so the app boots without crashing.

VITE_API_URL=http://localhost:5173/mock-api
VITE_COGNITO_AUTHORITY=http://localhost:5173/mock-cognito
VITE_COGNITO_CLIENT_ID=mock-client-id
VITE_COGNITO_DOMAIN=localhost
VITE_COGNITO_SCOPE=openid profile email
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_COGNITO_LOGOUT_URI=http://localhost:5173
VITE_COGNITO_SILENT_REDIRECT_URI=http://localhost:5173/auth/silent-callback
VITE_GOOGLE_SEARCH_KEY=mock-google-search-key
VITE_GOOGLE_SEARCH_CX=mock-google-search-cx
VITE_LAMBDA_PARSER_DOMAIN=http://localhost:5173/mock-lambda
VITE_GTM_ID=
